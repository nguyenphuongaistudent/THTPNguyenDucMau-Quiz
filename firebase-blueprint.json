{
  "entities": {
    "User": {
      "title": "User",
      "description": "Thông tin người dùng và vai trò trong hệ thống.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID người dùng từ Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "Email người dùng" },
        "username": { "type": "string", "description": "Tên đăng nhập duy nhất" },
        "displayName": { "type": "string", "description": "Tên hiển thị" },
        "school": { "type": "string", "description": "Trường học" },
        "class": { "type": "string", "description": "Lớp học" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student", "student-vip", "guest"], "description": "Vai trò người dùng" },
        "isApproved": { "type": "boolean", "description": "Trạng thái phê duyệt tài khoản" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Ngày tạo tài khoản" }
      },
      "required": ["uid", "email", "role"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "Thông tin về bộ đề thi trắc nghiệm.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Tiêu đề bài thi" },
        "description": { "type": "string", "description": "Mô tả bài thi" },
        "subject": { "type": "string", "description": "Môn học (Toán, Lý, Hóa...)" },
        "topic": { "type": "string", "enum": ["regular", "periodic", "graduation"], "description": "Chủ đề bài thi" },
        "duration": { "type": "integer", "description": "Thời gian làm bài (phút)" },
        "maxAttempts": { "type": "integer", "description": "Số lượt thi tối đa" },
        "createdBy": { "type": "string", "description": "UID của admin tạo đề" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Ngày tạo đề" },
        "isActive": { "type": "boolean", "description": "Trạng thái đề thi" },
        "allowedRoles": {
          "type": "array",
          "items": { "type": "string", "enum": ["student", "student-vip", "guest"] },
          "description": "Các vai trò được phép tham gia thi"
        },
        "reviewRoles": {
          "type": "array",
          "items": { "type": "string", "enum": ["student", "student-vip", "guest"] },
          "description": "Các vai trò được phép xem lại bài thi"
        },
        "specialAttemptLimits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["class", "student"] },
              "targetId": { "type": "string" },
              "maxAttempts": { "type": "integer" }
            }
          },
          "description": "Giới hạn lượt thi đặc biệt cho lớp hoặc học sinh cụ thể"
        }
      },
      "required": ["title", "duration", "createdBy"]
    },
    "Question": {
      "title": "Question",
      "description": "Câu hỏi trong một bộ đề thi.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["multiple_choice", "true_false"], "description": "Loại câu hỏi" },
        "text": { "type": "string", "description": "Nội dung câu hỏi" },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Danh sách các lựa chọn trả lời"
        },
        "correctOptionIndex": { "type": "integer", "description": "Vị trí của đáp án đúng (0-based) cho câu hỏi nhiều lựa chọn" },
        "correctAnswers": {
          "type": "array",
          "items": { "type": "boolean" },
          "description": "Danh sách đáp án Đúng/Sai cho 4 ý (a, b, c, d)"
        },
        "explanation": { "type": "string", "description": "Giải thích đáp án" }
      },
      "required": ["type", "text", "options"]
    },
    "Result": {
      "title": "Result",
      "description": "Kết quả làm bài thi của học sinh.",
      "type": "object",
      "properties": {
        "quizId": { "type": "string", "description": "ID của bài thi" },
        "studentUid": { "type": "string", "description": "UID của học sinh" },
        "studentName": { "type": "string", "description": "Tên học sinh" },
        "score": { "type": "number", "description": "Điểm số đạt được" },
        "totalQuestions": { "type": "integer", "description": "Tổng số câu hỏi" },
        "correctAnswers": { "type": "integer", "description": "Số câu trả lời đúng" },
        "completedAt": { "type": "string", "format": "date-time", "description": "Thời gian nộp bài" },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "val": { "type": "any" },
              "isCorrect": { "type": "boolean" }
            }
          },
          "description": "Danh sách các đáp án chi tiết học sinh đã chọn"
        }
      },
      "required": ["quizId", "studentUid", "score", "completedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "Thông tin người dùng" },
    "/quizzes/{quizId}": { "schema": "Quiz", "description": "Danh sách các bài thi" },
    "/quizzes/{quizId}/questions/{questionId}": { "schema": "Question", "description": "Câu hỏi của từng bài thi" },
    "/results/{resultId}": { "schema": "Result", "description": "Kết quả thi của học sinh" }
  }
}
